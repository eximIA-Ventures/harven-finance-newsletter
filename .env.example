# Required: Anthropic API key for AI summaries
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required: Resend API key for email sending
RESEND_API_KEY=re_...

# Optional: From email (must be verified in Resend)
RESEND_FROM_EMAIL=newsletter@harvenfinance.com.br

# Optional: Base URL (used by cron + unsubscribe links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: Secret for cron endpoint auth
CRON_SECRET=your-secret-here
